@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/dashboard.css" rel="stylesheet" />

<div class="container-fluid py-4">

    <div class="d-flex align-items-center mb-4">
        <h4 class="mb-0 fw-bold">Panel de administracion</h4>
        <small class="text-muted ms-3" id="fechaActual"></small>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card h-100 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Usuarios</p>
                    <div class="stat-numero" id="kpiUsuarios">
                        <span class="shimmer" style="width:40px;height:32px"></span>
                    </div>
                    <small class="text-muted" id="kpiActivos"></small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card verde h-100 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Productos</p>
                    <div class="stat-numero" id="kpiProductos">
                        <span class="shimmer" style="width:40px;height:32px"></span>
                    </div>
                    <small class="text-muted" id="kpiStockBajo"></small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card naranja h-100 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Ventas totales</p>
                    <div class="stat-numero" id="kpiVentas" style="font-size:1.4rem">
                        <span class="shimmer" style="width:70px;height:32px"></span>
                    </div>
                    <small class="text-muted" id="kpiOrdenesLabel"></small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card h-100 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Ordenes</p>
                    <div class="stat-numero" id="kpiOrdenes">
                        <span class="shimmer" style="width:40px;height:32px"></span>
                    </div>
                    <small class="text-muted" id="kpiOrdenesDetalle"></small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card verde h-100 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Entregadas</p>
                    <div class="stat-numero" id="kpiEntregadas">
                        <span class="shimmer" style="width:40px;height:32px"></span>
                    </div>
                    <small class="text-muted">completadas</small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card rojo h-100 shadow-sm">
                <div class="card-body">
                    <p class="text-muted small mb-1">Resenas pendientes</p>
                    <div class="stat-numero" id="kpiResenas">
                        <span class="shimmer" style="width:40px;height:32px"></span>
                    </div>
                    <small class="text-muted" id="kpiResenasTotal"></small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <span class="fw-semibold">Ultimas ordenes</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Numero</th>
                                <th>Cliente</th>
                                <th>Total</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody id="ordenesBody">
                            @for (int i = 0; i < 5; i++)
                            {
                                <tr>
                                    <td><span class="shimmer" style="width:80px;height:14px"></span></td>
                                    <td><span class="shimmer" style="width:120px;height:14px"></span></td>
                                    <td><span class="shimmer" style="width:60px;height:14px"></span></td>
                                    <td><span class="shimmer" style="width:70px;height:14px"></span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <span class="fw-semibold">Productos con stock bajo</span>
                </div>
                <div class="card-body" id="stockContainer">
                    @for (int i = 0; i < 5; i++)
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="shimmer" style="width:130px;height:13px"></span>
                                <span class="shimmer" style="width:30px;height:13px"></span>
                            </div>
                            <div class="progress" style="height:8px">
                                <div class="progress-bar" style="width:0%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

</div>

<script src="~/Scripts/jquery-3.7.1.min.js"></script>
<script src="~/Scripts/dashboard.js"></script>
