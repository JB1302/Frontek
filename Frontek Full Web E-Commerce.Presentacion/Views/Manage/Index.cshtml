﻿@model Frontek_Full_Web_E_Commerce.Presentacion.Models.VerifyPhoneNumberViewModel
@{
    ViewBag.Title = "Administrar cuenta";
}

<main class="container py-4" aria-labelledby="title">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">

            <div class="mb-4 text-center">
                <h2 id="title" class="fw-bold mb-2">@ViewBag.Title</h2>
                <p class="text-muted mb-0">Gestiona la configuración y seguridad de tu cuenta.</p>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.StatusMessage as string))
            {
                <div class="alert alert-success shadow-sm rounded-3">
                    @ViewBag.StatusMessage
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">

                    <h4 class="fw-semibold mb-4">Configuración de la cuenta</h4>

                    <div class="row g-4">

                        <!-- Contraseña -->
                        <div class="col-12">
                            <div class="border rounded-4 p-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                <div class="mb-3 mb-md-0">
                                    <h5 class="mb-1">Contraseña</h5>
                                    <p class="text-muted mb-0">
                                        @(Model.HasPassword ? "Tu cuenta ya tiene una contraseña configurada." : "Aún no has creado una contraseña.")
                                    </p>
                                </div>
                                <div>
                                    @if (Model.HasPassword)
                                    {
                                        @Html.ActionLink("Cambiar contraseña", "ChangePassword", null, new { @class = "btn btn-outline-primary" })
                                    }
                                    else
                                    {
                                        @Html.ActionLink("Crear contraseña", "SetPassword", null, new { @class = "btn btn-primary" })
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Inicios de sesión externos -->
                        <div class="col-12">
                            <div class="border rounded-4 p-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                <div class="mb-3 mb-md-0">
                                    <h5 class="mb-1">Inicios de sesión externos</h5>
                                    <p class="text-muted mb-0">
                                        Tienes
                                        <span class="badge bg-secondary">@Model.Logins.Count</span>
                                        inicio(s) de sesión externo(s) vinculado(s).
                                    </p>
                                </div>
                                <div>
                                    @Html.ActionLink("Administrar", "ManageLogins", null, new { @class = "btn btn-outline-dark" })
                                </div>
                            </div>
                        </div>

                        <!-- Autenticación de dos factores -->
                        <div class="col-12">
                            <div class="border rounded-4 p-3">
                                <h5 class="mb-2">Autenticación de dos factores</h5>
                                <p class="text-muted mb-0">
                                    No hay ningún proveedor de autenticación en dos factores configurado.
                                    Consulta
                                    <a href="https://go.microsoft.com/fwlink/?LinkId=403804" target="_blank" rel="noopener noreferrer">
                                        este artículo
                                    </a>
                                    para ver cómo habilitar esta funcionalidad en tu aplicación ASP.NET.
                                </p>
                            </div>
                        </div>

                        <!-- Tarjeta -->
                        <div class="col-12">
                            <div class="border rounded-4 p-3">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3">
                                    <div class="mb-3 mb-md-0">
                                        <h5 class="mb-1">Tarjeta</h5>
                                        <p class="text-muted mb-0">Administra la tarjeta asociada a tu cuenta.</p>
                                    </div>
                                    <div>
                                        @if (Model.Tarjeta == null)
                                        {
                                            <span class="badge bg-warning text-dark">No registrada</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Registrada</span>
                                        }
                                    </div>
                                </div>

                                @if (Model.Tarjeta == null)
                                {
                                    <p class="mb-3">No tienes una tarjeta registrada.</p>
                                    @Html.ActionLink("Agregar tarjeta", "Create", "Tarjetas", null, new { @class = "btn btn-primary" })
                                }
                                else
                                {
                                    <p class="mb-3">Ya tienes una tarjeta registrada en tu cuenta.</p>
                                    <div class="d-flex flex-wrap gap-2">
                                        @Html.ActionLink("Ver detalles", "Details", "Tarjetas", null, new { @class = "btn btn-info text-white" })
                                        @Html.ActionLink("Eliminar", "Delete", "Tarjetas", null, new { @class = "btn btn-danger" })
                                    </div>
                                }
                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>
</main>