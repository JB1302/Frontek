﻿@model Frontek_Full_Web_E_Commerce.Presentacion.Models.RegisterViewModel

@{
    ViewBag.Title = "Registro";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-9 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold mb-2">@ViewBag.Title</h2>
                    <p class="text-muted mb-0">Crea tu cuenta para continuar en Frontek Store.</p>
                </div>

                @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { role = "form", @class = "w-100" }))
                {
                    @Html.AntiForgeryToken()

                    if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2 mb-4">
                            @Html.ValidationSummary(false, "")
                        </div>
                    }

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Nombre, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.Nombre, new
                        {
                            @class = "form-control form-control-lg rounded-3",
                            placeholder = "Ingresa tu nombre completo"
                        })
                        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger small d-block mt-1" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.Email, new
                        {
                            @class = "form-control form-control-lg rounded-3",
                            placeholder = "correo@ejemplo.com",
                            type = "email"
                        })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small d-block mt-1" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Password, new { @class = "form-label fw-semibold" })
                        @Html.PasswordFor(m => m.Password, new
                        {
                            @class = "form-control form-control-lg rounded-3",
                            placeholder = "Crea una contraseña"
                        })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small d-block mt-1" })
                    </div>

                    <div class="mb-4">
                        @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label fw-semibold" })
                        @Html.PasswordFor(m => m.ConfirmPassword, new
                        {
                            @class = "form-control form-control-lg rounded-3",
                            placeholder = "Confirma tu contraseña"
                        })
                        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small d-block mt-1" })
                    </div>

                    <div class="d-grid mb-3">
                        <input type="submit" value="Registrarse" class="btn btn-primary btn-lg rounded-pill" />
                    </div>

                    <div class="text-center">
                        <span class="text-muted">¿Ya tienes cuenta?</span>
                        @Html.ActionLink(" Inicia sesión", "Login", "Account", null, new { @class = "text-decoration-none fw-semibold" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}