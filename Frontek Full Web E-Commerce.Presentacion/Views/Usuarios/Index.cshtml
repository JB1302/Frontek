@model IEnumerable<Frontek.Models.ApplicationUser>
@using Microsoft.AspNet.Identity
@using Microsoft.AspNet.Identity.EntityFramework
@using Frontek.Models

@{
    ViewBag.Title = "Usuarios";
    var db = new ApplicationDbContext();
    var userManager = new UserManager<ApplicationUser>(new UserStore<ApplicationUser>(db));
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Usuarios</h2>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th>Activo</th>
                        <th>Última conexión</th>
                        @if (User.IsInRole("Administrador"))
                        {
                            <th class="text-end">Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var roles = userManager.GetRoles(item.Id);

                        <tr>
                            <td>@item.Nombre</td>
                            <td>@item.Email</td>
                            <td>@string.Join(", ", roles)</td>
                            <td>
                                @if (item.Activo)
                                {
                                    <span class="badge bg-success">Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>
                                @(item.UltimaConexion.HasValue
                                    ? item.UltimaConexion.Value.ToString("dd/MM/yyyy HH:mm")
                                    : "Sin registro")
                            </td>

                            @if (User.IsInRole("Administrador"))
                            {
                                <td class="text-end">
                                    @Html.ActionLink("Editar", "Edit", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-primary me-2" })
                                    @Html.ActionLink("Eliminar", "Delete", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-danger" })
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>