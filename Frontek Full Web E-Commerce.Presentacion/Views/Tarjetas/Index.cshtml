@model Frontek_Full_Web_E_Commerce.Domain.Entities.Tarjeta

@{
    ViewBag.Title = "Mi tarjeta";
}

<h2>Mi tarjeta</h2>

@if (Model == null)
{
    <p>No tienes tarjeta registrada.</p>

    @Html.ActionLink("Agregar tarjeta", "Create", null, new { @class = "btn btn-primary" })
}
else
{
    <div class="card p-3">
        <p><strong>Propietario:</strong> @Model.Propietario</p>
        <p><strong>Vencimiento:</strong> @Model.FechaVencimiento?.ToShortDateString()</p>

        <p><strong>Número:</strong> **** **** **** 1234</p>

        <div class="mt-2">
            @Html.ActionLink("Ver detalles", "Details", null, new { @class = "btn btn-info" })
            @Html.ActionLink("Eliminar", "Delete", null, new { @class = "btn btn-danger" })
        </div>
    </div>
}