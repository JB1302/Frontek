@model Frontek_Full_Web_E_Commerce.Models.Orden

@{
    ViewBag.Title = "Detalle de orden";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Detalle de orden</h2>

    <div>
        @if (User.IsInRole("Cliente"))
        {
            @Html.ActionLink("Volver", "MisPedidos", "Ordenes", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
        }
        else
        {
            @Html.ActionLink("Volver", "Index", "Ordenes", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
        }
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-6">
                <strong>Número de orden:</strong><br />
                @Model.NumeroOrden
            </div>
            <div class="col-md-6">
                <strong>Fecha:</strong><br />
                @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
            </div>
            <div class="col-md-6">
                <strong>Cliente:</strong><br />
                @Model.NombreCliente
            </div>
            <div class="col-md-6">
                <strong>Correo:</strong><br />
                @Model.EmailCliente
            </div>
            <div class="col-md-6">
                <strong>Dirección:</strong><br />
                @Model.DireccionEnvio
            </div>
            <div class="col-md-3">
                <strong>Ciudad:</strong><br />
                @Model.Ciudad
            </div>
            <div class="col-md-3">
                <strong>País:</strong><br />
                @Model.Pais
            </div>
            <div class="col-md-4">
                <strong>Método de pago:</strong><br />
                @Model.MetodoPago
            </div>
            <div class="col-md-4">
                <strong>Estado:</strong><br />
                @Model.Estado
            </div>
            <div class="col-md-4">
                <strong>Total:</strong><br />
                ₡@Model.Total.ToString("N2")
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <h4 class="fw-bold mb-3">Detalle de productos</h4>

        @if (Model.Detalles != null && Model.Detalles.Any())
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Cantidad</th>
                            <th>Precio</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
<tbody>
    @foreach (var detalle in Model.Detalles)
    {
        <tr>
            <td>@(detalle.NombreProducto ?? detalle.Producto?.NombreProducto)</td>
            <td>@detalle.Cantidad</td>
            <td>₡@detalle.PrecioUnitario.ToString("N2")</td>
            <td>₡@detalle.Subtotal.ToString("N2")</td>
        </tr>
    }
</tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">Esta orden no tiene detalles registrados.</p>
        }
    </div>
</div>