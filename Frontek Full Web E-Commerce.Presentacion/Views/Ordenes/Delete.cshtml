@model Frontek_Full_Web_E_Commerce.Models.Orden

@{
    ViewBag.Title = "Eliminar orden";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="fw-bold mb-3">Eliminar orden</h2>
                <p class="text-muted">¿Seguro que deseas eliminar esta orden?</p>

                <dl class="row">
                    <dt class="col-sm-4">Número</dt>
                    <dd class="col-sm-8">@Model.NumeroOrden</dd>

                    <dt class="col-sm-4">Cliente</dt>
                    <dd class="col-sm-8">@Model.NombreCliente</dd>

                    <dt class="col-sm-4">Correo</dt>
                    <dd class="col-sm-8">@Model.EmailCliente</dd>

                    <dt class="col-sm-4">Total</dt>
                    <dd class="col-sm-8">₡@Model.Total.ToString("N2")</dd>

                    <dt class="col-sm-4">Estado</dt>
                    <dd class="col-sm-8">@Model.Estado</dd>
                </dl>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger rounded-pill px-4">Eliminar</button>
                        @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>