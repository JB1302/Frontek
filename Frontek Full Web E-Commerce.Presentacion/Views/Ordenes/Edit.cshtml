﻿@model Frontek_Full_Web_E_Commerce.Domain.Entities.Orden

@{
    ViewBag.Title = "Editar orden";
}

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="fw-bold mb-4">Editar orden</h2>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.OrdenId)
                    @Html.HiddenFor(m => m.FechaCreacion)

                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <div class="row g-3">
                        <div class="col-md-6">
                            @Html.LabelFor(m => m.NumeroOrden, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.NumeroOrden, new { @class = "form-control" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.IdUsuario, "Usuario", new { @class = "form-label fw-semibold" })
                            @Html.DropDownList("IdUsuario", null, "Seleccione un usuario", new { @class = "form-select" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.NombreCliente, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.NombreCliente, new { @class = "form-control" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.EmailCliente, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.EmailCliente, new { @class = "form-control" })
                        </div>

                        <div class="col-md-12">
                            @Html.LabelFor(m => m.DireccionEnvio, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.DireccionEnvio, new { @class = "form-control" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.Ciudad, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.Ciudad, new { @class = "form-control" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.Pais, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.Pais, new { @class = "form-control" })
                        </div>

                        <div class="col-md-4">
                            @Html.LabelFor(m => m.Total, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.Total, new { @class = "form-control", type = "number", step = "0.01" })
                        </div>

                        <div class="col-md-4">
                            @Html.LabelFor(m => m.MetodoPago, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.MetodoPago, new { @class = "form-control" })
                        </div>

                        <div class="col-md-4">
                            @Html.LabelFor(m => m.Estado, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.Estado, new { @class = "form-control" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.FechaEntregaEstimada, new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.FechaEntregaEstimada, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Guardar cambios</button>
                        @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>