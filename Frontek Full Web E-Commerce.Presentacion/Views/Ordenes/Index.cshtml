@model IEnumerable<Frontek_Full_Web_E_Commerce.Domain.Entities.Orden>

@{
    ViewBag.Title = "Órdenes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Órdenes</h2>

    @if (User.IsInRole("Administrador") || User.IsInRole("Vendedor"))
    {
        @Html.ActionLink("Nueva orden", "Create", null, new { @class = "btn btn-primary rounded-pill px-4" })
    }
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Cliente</th>
                        <th>Correo</th>
                        <th>Fecha</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Método pago</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.NumeroOrden</td>
                            <td>@item.NombreCliente</td>
                            <td>@item.EmailCliente</td>
                            <td>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>₡@item.Total.ToString("N2")</td>
                            <td>
                                <span class="badge bg-secondary">@item.Estado</span>
                            </td>
                            <td>@item.MetodoPago</td>
                            <td class="text-end text-nowrap">
                                @Html.ActionLink("Ver", "Details", new { id = item.OrdenId }, new { @class = "btn btn-sm btn-outline-secondary me-1" })

                                @if (User.IsInRole("Administrador") || User.IsInRole("Vendedor"))
                                {
                                    @Html.ActionLink("Editar", "Edit", new { id = item.OrdenId }, new { @class = "btn btn-sm btn-outline-primary me-1" })
                                    @Html.ActionLink("Eliminar", "Delete", new { id = item.OrdenId }, new { @class = "btn btn-sm btn-outline-danger" })
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>