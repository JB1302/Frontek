@model Frontek_Full_Web_E_Commerce.Domain.Entities.Producto

@{
    ViewBag.Title = Model.NombreProducto;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }

    <div class="row">

        <!-- Imagenes del producto -->
        <div class="col-md-6">
            @if (Model.Imagen1 != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Imagen1)"
                     class="img-fluid mb-2" alt="Imagen 1" />
            }
            @if (Model.Imagen2 != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Imagen2)"
                     class="img-fluid mb-2" alt="Imagen 2" />
            }
            @if (Model.Imagen3 != null)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Imagen3)"
                     class="img-fluid mb-2" alt="Imagen 3" />
            }
            @if (Model.Imagen1 == null && Model.Imagen2 == null && Model.Imagen3 == null)
            {
                <div class="text-center text-muted p-5 border">Sin imagen</div>
            }
        </div>

        <!-- Info del producto -->
        <div class="col-md-6">
            <h2>@Model.NombreProducto</h2>

            <hr />

            <p><strong>Precio:</strong> &#8353;@Model.Precio.ToString("N2")</p>
            <p><strong>Stock:</strong> @Model.Stock unidades</p>
            <p>
                <strong>Estado:</strong>
                @if (Model.Activo)
                {
                    <span class="badge badge-success">Disponible</span>
                }
                else
                {
                    <span class="badge badge-secondary">No disponible</span>
                }
            </p>
            <p><strong>Fecha de ingreso:</strong> @Model.FechaIngreso.ToString("dd/MM/yyyy")</p>

            <hr />

            <div class="mt-3">
                <a href="@Url.Action("Index", "Producto")" class="btn btn-secondary">
                    Volver al catalogo
                </a>

                @if (User.IsInRole("Cliente") && Model.Activo)
                {
                    <a href="@Url.Action("Create", "Resena", new { productoId = Model.Id })"
                       class="btn btn-primary ml-2">
                        Escribir resena
                    </a>
                }

                @if (User.IsInRole("Administrador"))
                {
                    <a href="@Url.Action("Edit", "Producto", new { id = Model.Id })"
                       class="btn btn-warning ml-2">
                        Editar
                    </a>
                }
            </div>
        </div>

    </div>
</div>
