@model IEnumerable<Frontek_Full_Web_E_Commerce.Domain.Entities.Producto>

@{
    ViewBag.Title = "Nuevo Producto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap');

    body, .form-control, .btn, label {
        font-family: 'DM Sans', sans-serif;
    }

    .page-header {
        background: #1a1a2e;
        color: white;
        padding: 32px 0 24px;
        margin-bottom: 36px;
    }

        .page-header h2 {
            font-size: 1.8rem;
            font-weight: 600;
            margin: 0;
        }

    .form-card {
        background: white;
        border-radius: 16px;
        padding: 36px 40px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07);
        max-width: 760px;
        margin: 0 auto;
    }

    .section-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #999;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 1px solid #eee;
    }

    .form-control {
        border: 1.5px solid #e5e5e5;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.92rem;
        transition: border-color 0.2s;
    }

        .form-control:focus {
            border-color: #1a1a2e;
            box-shadow: none;
        }

    label {
        font-size: 0.88rem;
        font-weight: 500;
        color: #444;
        margin-bottom: 5px;
    }

    .img-preview-wrap {
        border: 2px dashed #ddd;
        border-radius: 12px;
        height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: #fafafa;
        cursor: pointer;
        transition: border-color 0.2s;
    }

        .img-preview-wrap:hover {
            border-color: #1a1a2e;
        }

        .img-preview-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 10px;
        }

    .img-placeholder {
        text-align: center;
        color: #bbb;
        font-size: 0.8rem;
    }

        .img-placeholder svg {
            margin-bottom: 6px;
        }

    .btn-guardar {
        background: #1a1a2e;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px 32px;
        font-size: 0.95rem;
        font-weight: 500;
        transition: background 0.2s;
    }

        .btn-guardar:hover {
            background: #e94560;
            color: white;
        }

    .btn-volver {
        border: 1.5px solid #ddd;
        border-radius: 10px;
        padding: 12px 24px;
        font-size: 0.95rem;
        color: #555;
        background: white;
        transition: all 0.2s;
    }

        .btn-volver:hover {
            border-color: #1a1a2e;
            color: #1a1a2e;
        }
</style>

<div class="page-header">
    <div class="container">
        <h2>Nuevo Producto</h2>
    </div>
</div>

<div class="container pb-5">
    <div class="form-card">

        @using (Html.BeginForm("Create", "Producto", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger rounded-3 mb-4" })

            <p class="section-label">Información general</p>

            <div class="row g-3 mb-4">
                <div class="col-12">
                    <label>@Html.DisplayNameFor(m => m.NombreProducto)</label>
                    @Html.TextBoxFor(m => m.NombreProducto, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.NombreProducto, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-4">
                    <label>Precio</label>
                    @Html.TextBoxFor(m => m.Precio, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Precio, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-4">
                    <label>Stock</label>
                    @Html.TextBoxFor(m => m.Stock, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-4">
                    <label>@Html.DisplayNameFor(m => m.FechaIngreso)</label>
                    @Html.TextBoxFor(m => m.FechaIngreso, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(m => m.FechaIngreso, "", new { @class = "text-danger small" })
                </div>
                <div class="col-md-6">
                    <div class="form-check mt-2">
                        @Html.CheckBoxFor(m => m.Activo, new { @class = "form-check-input" })
                        <label class="form-check-label">Producto activo</label>
                    </div>
                </div>
            </div>

            <p class="section-label">Imágenes del producto</p>

            <div class="row g-3 mb-4">
                @for (int i = 1; i <= 3; i++)
                {
                    string fieldName = "ImagenFile" + i;
                    string previewId = "preview" + i;
                    <div class="col-md-4">
                        <label>Imagen @i</label>
                        <div class="img-preview-wrap" onclick="document.getElementById('@fieldName').click()">
                            <img id="@previewId" src="#" alt="" style="display:none;" />
                            <div class="img-placeholder" id="placeholder@i">
                                <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="#ccc">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 20M14 8h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <div>Clic para subir</div>
                            </div>
                        </div>
                        <input type="file" id="@fieldName" name="@fieldName"
                               accept="image/*" style="display:none;"
                               onchange="previewImagen(this, '@previewId', 'placeholder@i')" />
                    </div>
                }
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-guardar btn">Guardar producto</button>
                @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn-volver btn" })
            </div>
        }
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        function previewImagen(input, previewId, placeholderId) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    var img = document.getElementById(previewId);
                    img.src = e.target.result;
                    img.style.display = 'block';
                    document.getElementById(placeholderId).style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
