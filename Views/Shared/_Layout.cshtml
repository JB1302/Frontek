@using Microsoft.AspNet.Identity

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewBag.Title | Frontek Store</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --color-primary: #6366f1;
            --color-primary-dark: #4f46e5;
            --color-accent: #f97316;
            --color-bg: #f4f5fb;
            --color-dark: #0f172a;
        }

        body {
            font-family: "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background-color: var(--color-bg);
            color: #111827;
        }

        .top-bar {
            background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
            color: #ffffff;
            font-size: 0.85rem;
            padding: 6px 0;
        }

            .top-bar a {
                color: #ffffff;
                text-decoration: underline;
                text-decoration-thickness: 1px;
                text-underline-offset: 2px;
            }

        .navbar {
            background-color: #ffffff;
            box-shadow: 0 4px 18px rgba(15, 23, 42, 0.08);
        }

        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.04em;
            color: var(--color-primary-dark) !important;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            margin-right: 1rem;
        }

        .nav-link {
            font-weight: 500;
            color: #4b5563 !important;
            padding: 0.45rem 0.9rem !important;
            border-radius: 999px;
            transition: all 0.18s ease-in-out;
            display: inline-flex;
            align-items: center;
            white-space: nowrap;
        }

            .nav-link:hover,
            .nav-link.active {
                color: var(--color-primary-dark) !important;
                background-color: rgba(99, 102, 241, 0.07);
            }

        .search-box {
            max-width: 380px;
            width: 100%;
        }

        .search-input {
            border-radius: 999px;
            border: 1px solid #e5e7eb;
            padding-left: 2.4rem;
            padding-right: 1rem;
            font-size: 0.9rem;
        }

            .search-input:focus {
                border-color: var(--color-primary);
                box-shadow: 0 0 0 1px rgba(99, 102, 241, 0.25);
            }

        .search-icon {
            position: absolute;
            left: 0.9rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 0.95rem;
        }

        .nav-center {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .nav-main {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            margin-bottom: 0;
        }

        .icon-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 0.5rem;
            min-height: 44px;
        }

        .icon-btn {
            border-radius: 999px;
            padding: 0.45rem 0.8rem;
            border: 1px solid transparent;
            background-color: transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
            font-size: 0.9rem;
            color: #4b5563;
            transition: all 0.15s ease-in-out;
            text-decoration: none;
            line-height: 1.2;
            white-space: nowrap;
        }

            .icon-btn:hover {
                border-color: #e5e7eb;
                background-color: #f9fafb;
                color: var(--color-primary-dark);
                text-decoration: none;
            }

        .logout-form {
            display: inline-flex;
            align-items: center;
            margin: 0;
        }

        .logout-btn {
            border-radius: 999px;
            padding: 0.45rem 0.8rem;
            border: 1px solid transparent;
            background-color: transparent;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.35rem;
            font-size: 0.9rem;
            color: #dc3545;
            transition: all 0.15s ease-in-out;
            line-height: 1.2;
            white-space: nowrap;
        }

            .logout-btn:hover {
                border-color: #e5e7eb;
                background-color: #fff5f5;
                color: #b02a37;
            }

        .icon-badge {
            position: relative;
        }

        .icon-badge-count {
            position: absolute;
            top: -5px;
            right: -2px;
            min-width: 16px;
            height: 16px;
            border-radius: 999px;
            background-color: var(--color-accent);
            color: #ffffff;
            font-size: 0.7rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 3px;
        }

        .content-wrapper {
            min-height: calc(100vh - 190px);
            padding-top: 24px;
            padding-bottom: 40px;
        }

        .content-card {
            background-color: #ffffff;
            border-radius: 1.25rem;
            padding: 1.75rem;
            box-shadow: 0 14px 40px rgba(15, 23, 42, 0.06);
        }

        footer {
            background-color: #ffffff;
            border-top: 1px solid #e5e7eb;
            padding: 18px 0;
            font-size: 0.85rem;
            color: #6b7280;
        }

            footer a {
                color: var(--color-primary-dark);
                text-decoration: none;
            }

                footer a:hover {
                    text-decoration: underline;
                }

        .btn-primary {
            background: linear-gradient(90deg, var(--color-primary), var(--color-primary-dark));
            border-color: var(--color-primary-dark);
            border-radius: 999px;
            font-weight: 500;
            padding-inline: 1.4rem;
        }

            .btn-primary:hover {
                background: linear-gradient(90deg, var(--color-primary-dark), var(--color-primary));
            }

        @@media (min-width: 992px) {
            .navbar .container {
                display: grid;
                grid-template-columns: auto minmax(260px, 380px) 1fr auto;
                align-items: center;
                column-gap: 1rem;
            }

            .navbar-collapse {
                display: contents !important;
            }

            .search-box {
                margin: 0 !important;
            }
        }

        @@media (max-width: 991.98px) {
            .navbar-collapse {
                padding-top: 0.75rem;
            }

            .nav-center {
                justify-content: flex-start;
                margin-top: 0.75rem;
            }

            .nav-main {
                align-items: flex-start;
            }

            .icon-actions {
                justify-content: flex-start;
                margin-top: 0.75rem;
                flex-wrap: wrap;
            }
        }

        @@media (max-width: 767.98px) {
            .content-card {
                border-radius: 1rem;
                padding: 1.15rem;
            }

            .search-box {
                max-width: 100%;
                margin-top: 0.5rem;
            }
        }
    </style>
</head>

<body>

    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <span>
                🚚 Envío gratis en compras superiores a <strong>₡50.000</strong>
            </span>
            <span class="d-none d-sm-inline">
                ¿Necesitás ayuda? <a href="#">Contáctanos</a>
            </span>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg">
        <div class="container">

            @Html.ActionLink(
                linkText: "Frontek",
                actionName: "Index",
                controllerName: "Home",
                routeValues: null,
                htmlAttributes: new { @class = "navbar-brand" }
            )

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">

                <div class="search-box my-2 my-lg-0">
                    <div class="position-relative">
                        <i class="bi bi-search search-icon"></i>
                        <input type="search"
                               class="form-control search-input"
                               placeholder="Buscar productos, categorías o marcas..." />
                    </div>
                </div>

                <div class="nav-center">
                    <ul class="navbar-nav nav-main">
                        <li class="nav-item">
                            @Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })
                        </li>

                        @if (Request.IsAuthenticated && User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                @Html.ActionLink("Usuarios", "Index", "Usuarios", null, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item">
                                @Html.ActionLink("Roles", "Index", "Rols", null, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item">
                                @Html.ActionLink("Productos", "Index", "Producto", null, new { @class = "nav-link" })
                            </li>
                            <li class="nav-item">
                                @Html.ActionLink("Órdenes", "Index", "Ordens", null, new { @class = "nav-link" })
                            </li>
                        }
                        else if (Request.IsAuthenticated && User.IsInRole("Vendedor"))
                        {
                   
                            <li class="nav-item">
                                @Html.ActionLink("Órdenes", "Index", "Ordens", null, new { @class = "nav-link" })
                            </li>
                        }
                        else if (Request.IsAuthenticated && User.IsInRole("Cliente"))
                        {
                                     <li class="nav-item">
             @Html.ActionLink("Productos", "Index", "Producto", null, new { @class = "nav-link" })
         </li>
                            <li class="nav-item">
                                @Html.ActionLink("Mis pedidos", "MisPedidos", "Ordens", null, new { @class = "nav-link" })
                            </li>
                        }
                    </ul>
                </div>

                <div class="icon-actions">
                    @if (Request.IsAuthenticated)
                    {
                        <a href="@Url.Action("Index", "Manage")" class="icon-btn">
                            <i class="bi bi-person-fill fs-5"></i>
                            <span class="d-none d-sm-inline">@User.Identity.GetUserName()</span>
                        </a>

                        if (User.IsInRole("Cliente"))
                        {
                            <a href="@Url.Action("Index", "Carrito")" class="icon-btn icon-badge">
                                <i class="bi bi-bag-check fs-5"></i>
                                <span class="icon-badge-count">0</span>
                                <span class="d-none d-sm-inline">Carrito</span>
                            </a>
                        }

                        using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm", @class = "logout-form" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="logout-btn">
                                <i class="bi bi-box-arrow-right fs-5"></i>
                                <span class="d-none d-sm-inline">Salir</span>
                            </button>
                        }
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="icon-btn">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span class="d-none d-sm-inline">Ingresar</span>
                        </a>

                        <a href="@Url.Action("Register", "Account")" class="icon-btn">
                            <i class="bi bi-person-plus fs-5"></i>
                            <span class="d-none d-sm-inline">Registro</span>
                        </a>
                    }
                </div>

            </div>
        </div>
    </nav>

    <main class="container content-wrapper">
        <div class="content-card">
            @RenderBody()
        </div>
    </main>

    <footer>
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <span>
                &copy; @DateTime.Now.Year · Frontek Store · Todos los derechos reservados
            </span>
            <span>
                <a href="#">Términos</a> · <a href="#">Privacidad</a>
            </span>
        </div>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

</body>
</html>