@using Microsoft.AspNet.Identity

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewBag.Title | Frontek Store</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

</head>
<body>

    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <span>
                Envío gratis en compras superiores a <strong>₡50.000</strong>
            </span>
            <span class="d-none d-sm-inline">
                ¿Necesitás ayuda? <a href="#">Contáctanos</a>
            </span>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            @Html.ActionLink(
                linkText: "Frontek",
                actionName: "Index",
                controllerName: "Home",
                routeValues: null,
                htmlAttributes: new { @class = "navbar-brand d-lg-none" }
            )

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <div class="navbar-flex">

                    <div class="navbar-left">
                        @Html.ActionLink(
                            linkText: "Frontek",
                            actionName: "Index",
                            controllerName: "Home",
                            routeValues: null,
                            htmlAttributes: new { @class = "navbar-brand d-none d-lg-flex" }
                        )

                        <div class="search-box">
                            <div class="position-relative">
                                <i class="bi bi-search search-icon"></i>
                                <input type="search"
                                       class="form-control search-input"
                                       placeholder="Buscar productos, categorías o marcas..." />
                            </div>
                        </div>
                    </div>

                    <div class="navbar-center">
                        <ul class="navbar-nav-custom">
                            <li class="nav-item">
                                @Html.ActionLink("Inicio", "Index", "Home", null, new { @class = "nav-link" })
                            </li>

                            @if (Request.IsAuthenticated && User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    @Html.ActionLink("Usuarios", "Index", "Usuarios", null, new { @class = "nav-link" })
                                </li>
                                <li class="nav-item">
                                    @Html.ActionLink("Productos", "Index", "Producto", null, new { @class = "nav-link" })
                                </li>
                                <li class="nav-item">
                                    @Html.ActionLink("Órdenes", "Index", "Ordenes", null, new { @class = "nav-link" })
                                </li>
                            }
                            else if (Request.IsAuthenticated && User.IsInRole("Vendedor"))
                            {
                                <li class="nav-item">
                                    @Html.ActionLink("Productos", "Index", "Producto", null, new { @class = "nav-link" })
                                </li>
                                <li class="nav-item">
                                    @Html.ActionLink("Órdenes", "Index", "Ordenes", null, new { @class = "nav-link" })
                                </li>
                            }
                            else if (Request.IsAuthenticated && User.IsInRole("Cliente"))
                            {
                                <li class="nav-item">
                                    @Html.ActionLink("Mis pedidos", "MisPedidos", "Ordenes", null, new { @class = "nav-link" })
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="navbar-right">
                        @if (Request.IsAuthenticated)
                        {
                            <a href="@Url.Action("Index", "Manage")" class="icon-btn">
                                <i class="bi bi-person-fill fs-5"></i>
                                <span class="d-none d-sm-inline">@User.Identity.GetUserName()</span>
                            </a>

                            if (User.IsInRole("Cliente"))
                            {
                                <a href="@Url.Action("Index", "Carrito")" class="icon-btn icon-badge">
                                    <i class="bi bi-bag-check fs-5"></i>
                                    <span class="icon-badge-count">0</span>
                                    <span class="d-none d-sm-inline">Carrito</span>
                                </a>
                            }

                            using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm", @class = "logout-form" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="logout-btn">
                                    <i class="bi bi-box-arrow-right fs-5"></i>
                                    <span class="d-none d-sm-inline">Salir</span>
                                </button>
                            }
                        }
                        else
                        {
                            <a href="@Url.Action("Login", "Account")" class="icon-btn">
                                <i class="bi bi-person-circle fs-5"></i>
                                <span class="d-none d-sm-inline">Ingresar</span>
                            </a>

                            <a href="@Url.Action("Register", "Account")" class="icon-btn">
                                <i class="bi bi-person-plus fs-5"></i>
                                <span class="d-none d-sm-inline">Registro</span>
                            </a>
                        }
                    </div>

                </div>
            </div>
        </div>
    </nav>

    <main class="container content-wrapper">
        <div class="content-card">
            @RenderBody()
        </div>
    </main>

    <footer>
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <span>
                &copy; @DateTime.Now.Year · Frontek Store · Todos los derechos reservados
            </span>
            <span>
                <a href="#">Términos</a> · <a href="#">Privacidad</a>
            </span>
        </div>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

</body>
</html>