@model IEnumerable<Frontek_Full_Web_E_Commerce.Models.Producto>

@{
    ViewBag.Title = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Productos</h2>

    @if (User.IsInRole("Administrador") || User.IsInRole("Vendedor"))
    {
        @Html.ActionLink("Nuevo producto", "Create", null, new { @class = "btn btn-primary rounded-pill px-4" })
    }
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Imagen</th>
                        <th>Nombre</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var producto in Model)
                    {
                        <tr>
                            <td>
                                @if (producto.Imagen1 != null && producto.Imagen1.Length > 0)
                                {
                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(producto.Imagen1)"
                                         alt="@producto.NombreProducto"
                                         style="width:56px; height:56px; object-fit:cover; border-radius:8px;" />
                                }
                                else
                                {
                                    <div style="width:56px; height:56px; background:#f0f0f0; border-radius:8px;
                                                display:flex; align-items:center; justify-content:center;
                                                font-size:0.7rem; color:#aaa;">
                                        Sin img
                                    </div>
                                }
                            </td>
                            <td>@producto.NombreProducto</td>
                            <td>₡@producto.Precio.ToString("N2")</td>
                            <td><
                                @if (producto.Stock <= 0)
                                {
                                    <span class="badge bg-danger">Agotado</span>
                                }
                                else if (producto.Stock <= 5)
                                {
                                    <span class="badge bg-warning text-dark">@producto.Stock (pocas)</span>
                                }
                                else
                                {
                                    @producto.Stock
                                }
                            </td>
                            <td>
                                <span class="badge @(producto.Activo ? "bg-success" : "bg-secondary")">
                                    @(producto.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                @Html.ActionLink("Ver", "Details", new { id = producto.Id }, new { @class = "btn btn-sm btn-outline-secondary me-2" })

                                @if (User.IsInRole("Administrador") || User.IsInRole("Vendedor"))
                                {
                                    @Html.ActionLink("Editar", "Edit", new { id = producto.Id }, new { @class = "btn btn-sm btn-outline-primary me-2" })
                                    @Html.ActionLink("Eliminar", "Delete", new { id = producto.Id }, new { @class = "btn btn-sm btn-outline-danger" })
                                }
                                @Html.ActionLink("Agregar", "Agregar", "Carrito",
                                new { id = producto.Id },
                                new { @class = "btn btn-sm btn-success me-2" })
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>