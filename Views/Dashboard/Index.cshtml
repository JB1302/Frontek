@{
    ViewBag.Title = "Dashboard";
}


<h3>Dashboard</h3>
<p class="text-muted">Informacion general del sistema</p>
<hr />

<div id="msgError" class="alert alert-danger" style="display:none;">
    Hubo un problema al cargar los datos
</div>

<div class="row">
    <div class="col-md-3 col-6">
        <div class="caja-stat">
            <div class="etiqueta">Usuarios registrados</div>
            <div class="numero-grande" id="numUsuarios">...</div>
            <small class="text-success" id="numActivos"></small>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="caja-stat">
            <div class="etiqueta">Productos en catalogo</div>
            <div class="numero-grande" id="numProductos">...</div>
            <small class="text-warning" id="numBajoStock"></small>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="caja-stat">
            <div class="etiqueta">Ordenes totales</div>
            <div class="numero-grande" id="numOrdenes">...</div>
            <small class="text-muted" id="numEntregadas"></small>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="caja-stat">
            <div class="etiqueta">Ventas totales</div>
            <div class="numero-grande text-success" id="numVentas">...</div>
            <small class="text-muted">acumulado</small>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="seccion">
            <h5>Estado de ordenes</h5>
            <div id="contenidoBarras">
                <p class="text-muted">Cargando...</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="seccion">
            <h5>Resenas</h5>
            <p>Total: <strong id="numResenas">...</strong></p>
            <p id="resenasAlert"></p>
            <a href="@Url.Action("Index","Resena")" class="btn btn-sm btn-outline-secondary">
                Ir a moderacion
            </a>
        </div>
    </div>
</div>

<div class="seccion">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Ultimas 5 ordenes</h5>
        <a href="@Url.Action("Index","Ordenes")" class="btn btn-sm btn-outline-primary">Ver todas</a>
    </div>
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Orden</th>
                <th>Cliente</th>
                <th>Total</th>
                <th>Estado</th>
                <th>Fecha</th>
            </tr>
        </thead>
        <tbody id="filaOrdenes">
            <tr><td colspan="5" class="text-center text-muted">Cargando...</td></tr>
        </tbody>
    </table>
</div>

<div class="seccion" id="seccionStock" style="display:none;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Productos con stock bajo <span class="badge bg-warning text-dark">Atencion</span></h5>
        <a href="@Url.Action("Index","Producto")" class="btn btn-sm btn-outline-secondary">Ver productos</a>
    </div>
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr><th>Producto</th><th>Stock</th><th>Precio</th></tr>
        </thead>
        <tbody id="filaStock"></tbody>
    </table>
</div>

<div class="mb-4">
    <h5>Accesos directos</h5>
    <a href="@Url.Action("Index","Usuarios")" class="btn btn-outline-secondary me-2 mb-2">Usuarios</a>
    <a href="@Url.Action("Index","Producto")" class="btn btn-outline-secondary me-2 mb-2">Productos</a>
    <a href="@Url.Action("Index","Ordenes")" class="btn btn-outline-secondary me-2 mb-2">Ordenes</a>
    <a href="@Url.Action("Index","Resena")" class="btn btn-outline-secondary me-2 mb-2">Reseñas</a>
</div>
@section Scripts {
    <script>
        var urlStats   = '@Url.Action("GetStats",          "Dashboard")';
        var urlOrdenes = '@Url.Action("GetUltimasOrdenes", "Dashboard")';
        var urlStock   = '@Url.Action("GetStockBajo",      "Dashboard")';
    </script>
    <script src="~/Scripts/dashboard.js"></script>
}
