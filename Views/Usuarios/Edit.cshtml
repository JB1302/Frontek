@model Frontek.Models.ApplicationUser

@{
    ViewBag.Title = "Editar usuario";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h2 class="fw-bold mb-4">Editar usuario</h2>

                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()

                    @Html.Hidden("Id", Model.Id)

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre</label>
                        <input type="text" name="Nombre" value="@Model.Nombre" class="form-control" />
                        @Html.ValidationMessage("Nombre", "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Correo electrónico</label>
                        <input type="email" name="Email" value="@Model.Email" class="form-control" />
                        @Html.ValidationMessage("Email", "", new { @class = "text-danger small" })
                    </div>

                    <div class="form-check mb-3">
                        <input type="checkbox" name="Activo" value="true" class="form-check-input" @(Model.Activo ? "checked" : "") />
                        <label class="form-check-label">Activo</label>
                    </div>
                    <input type="hidden" name="Activo" value="false" />

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Rol</label>
                        @Html.DropDownList("RolSeleccionado", (SelectList)ViewBag.RolesDisponibles, "Seleccione un rol", new { @class = "form-select" })
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Guardar</button>
                        @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>